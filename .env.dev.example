# =============================================================================
# V2C Cloud — Dev Environment Secrets (template)
# =============================================================================
#
# SINGLE source of truth for every secret used by the local dev environment.
# Copy this file to `.env.dev` (gitignored) and fill in the values, then
# (re)open the workspace in the dev container. `scripts/setup` reads
# `.env.dev` and wires the variables into every interactive shell via an
# idempotent block in `~/.bashrc`.
#
# After editing `.env.dev`:
#   1. Open a new terminal in the dev container so the exports are loaded, OR
#   2. Run `source ~/.bashrc` in the current terminal,
# then restart Claude Code if it needs to consume any of the values (e.g.
# the Home Assistant MCP server reads HASS_TOKEN at spawn time).
#
# Every value below is LOCAL-ONLY (your workstation's dev HA + dev V2C
# account). None of these reach production. `.env.dev` is gitignored.
#
# Format: shell-style `KEY=value`, one per line, no quotes around the value,
# no trailing spaces. Lines starting with `#` are comments. The file is
# sourced with `set -a; . .env.dev; set +a`, so every assignment is exported.
# =============================================================================


# -----------------------------------------------------------------------------
# GitHub CLI
# -----------------------------------------------------------------------------
# Personal access token for `gh` running inside the dev container. Persists
# `gh` auth across dev-container rebuilds.
#
# Where to get it:
#   https://github.com/settings/tokens (classic) — scopes: at least `repo`
#   and `read:org` if you work against private org repos. Fine-grained tokens
#   also work; `gh auth login --with-token` requires `read:org`, but using
#   the env var skips that check.
GH_TOKEN=


# -----------------------------------------------------------------------------
# V2C Cloud
# -----------------------------------------------------------------------------
# API key for the V2C Cloud public API, consumed by
# `scripts/live_smoke_test.py` (expects `V2C_CLOUD_API_KEY`).
#
# Where to get it:
#   https://v2c.cloud/home/user → "User → API" → "Get token".
V2C_CLOUD_API_KEY=

# Local IP of your dev Trydan charger, reachable from the dev container host.
# Required by `scripts/live_smoke_test.py` (expects `V2C_LOCAL_IP`).
# Example: 10.35.0.50
V2C_LOCAL_IP=


# -----------------------------------------------------------------------------
# Home Assistant — companion `hass_core_dev` container
# -----------------------------------------------------------------------------
# Long-lived access token for the dev Home Assistant instance launched by
# `docker-compose.yml`. Consumed by `mcp-proxy` (spawned by Claude Code via
# `.mcp.json`) to authenticate against `http://homeassistant:8123/api/mcp`.
#
# Where to get it:
#   Home Assistant UI → click your user avatar (bottom left) → Security tab →
#   "Long-Lived Access Tokens" → "Create Token".
HASS_TOKEN=
